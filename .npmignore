# What gets published is defined by the "files" allowlist in package.json.
#
# This file exists only to strip build artifacts that can appear *inside* the
# allowlisted directories, and to stop npm from falling back to .gitignore
# (which excludes dist/ and would otherwise ship nothing).
#
# It MUST NOT exclude dist/, bin/, binding.gyp or the native sources.

# Intermediate TypeScript output. `tsc` emits to dist/build/; scripts/build.js
# then assembles the publishable files into dist/ proper. Ship the result,
# not the intermediate tree.
dist/build/

# Native build intermediates. The compiled .node binary is delivered through
# the platform-specific optionalDependencies (or rebuilt by the install
# scripts) — it is never bundled into this package.
build/
.node-gyp/
*.o
*.obj
*.node
*.a
*.lib

# Caches, logs, editor and OS noise
*.tsbuildinfo
*.log
.DS_Store
Thumbs.db
